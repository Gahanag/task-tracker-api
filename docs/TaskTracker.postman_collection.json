{
  "info": {
    "name": "Task Tracker API",
    "description": "Complete Postman collection for Team Task Tracker API\n\nQuick Start:\n1. Run: docker compose up\n2. POST /api/v1/auth/login with admin@acme.com / Admin@1234\n3. The 'Login' request auto-saves the token — all other requests use it automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "taskId", "value": "", "type": "string" },
    { "key": "projectId", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Admin\",\n  \"email\": \"alice@neworg.com\",\n  \"password\": \"Admin@1234\",\n  \"organizationName\": \"New Org\",\n  \"role\": \"ADMIN\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  const data = pm.response.json().data;",
                "  pm.collectionVariables.set('accessToken', data.accessToken);",
                "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Login (Admin)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@acme.com\",\n  \"password\": \"Admin@1234\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  const data = pm.response.json().data;",
                "  pm.collectionVariables.set('accessToken', data.accessToken);",
                "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
                "  pm.test('Login successful', () => pm.expect(data).to.have.property('accessToken'));",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Login (Manager)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"manager@acme.com\",\n  \"password\": \"Manager@1234\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { const d = pm.response.json().data; pm.collectionVariables.set('accessToken', d.accessToken); pm.collectionVariables.set('refreshToken', d.refreshToken); }"] } }]
        },
        {
          "name": "Login (Member)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"member1@acme.com\",\n  \"password\": \"Member@1234\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { const d = pm.response.json().data; pm.collectionVariables.set('accessToken', d.accessToken); pm.collectionVariables.set('refreshToken', d.refreshToken); }"] } }]
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { const d = pm.response.json().data; pm.collectionVariables.set('accessToken', d.accessToken); pm.collectionVariables.set('refreshToken', d.refreshToken); }"] } }]
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Get Me",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List Projects",
          "request": { "method": "GET", "url": "{{baseUrl}}/projects" }
        },
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"My New Project\",\n  \"description\": \"A test project\"\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('projectId', pm.response.json().data.id); }"] } }]
        },
        {
          "name": "Get Project",
          "request": { "method": "GET", "url": "{{baseUrl}}/projects/{{projectId}}" }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/projects/{{projectId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Project Name\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Tasks",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/tasks?page=1&limit=10", "query": [{"key": "page", "value": "1"}, {"key": "limit", "value": "10"}] } }
        },
        {
          "name": "List Tasks — Filter by Status",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/tasks?status=TODO&priority=HIGH", "query": [{"key": "status", "value": "TODO"}, {"key": "priority", "value": "HIGH"}] } }
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tasks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Task from Postman\",\n  \"description\": \"Testing task creation\",\n  \"priority\": \"HIGH\",\n  \"projectId\": \"{{projectId}}\",\n  \"dueDate\": \"2027-12-31T00:00:00.000Z\"\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('taskId', pm.response.json().data.id); }"] } }]
        },
        {
          "name": "Get Task",
          "request": { "method": "GET", "url": "{{baseUrl}}/tasks/{{taskId}}" }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated Task Title\",\n  \"priority\": \"MEDIUM\"\n}" }
          }
        },
        {
          "name": "Update Status → IN_PROGRESS",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tasks/{{taskId}}/status",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}" }
          }
        },
        {
          "name": "Update Status → BLOCKED",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tasks/{{taskId}}/status",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"BLOCKED\",\n  \"note\": \"Waiting for design approval\"\n}" }
          }
        },
        {
          "name": "Update Status → DONE (invalid from BLOCKED)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tasks/{{taskId}}/status",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"DONE\"\n}" }
          }
        },
        {
          "name": "Delete Task (Admin only)",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/tasks/{{taskId}}" }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": { "method": "GET", "url": "{{baseUrl}}/users" }
        },
        {
          "name": "Get User",
          "request": { "method": "GET", "url": "{{baseUrl}}/users/{{userId}}" }
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/{{userId}}/role",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"MANAGER\"\n}" }
          }
        },
        {
          "name": "Deactivate User",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/users/{{userId}}" }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Get Analytics",
          "request": { "method": "GET", "url": "{{baseUrl}}/analytics" }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "http://localhost:3000/health"
          }
        }
      ]
    }
  ]
}
