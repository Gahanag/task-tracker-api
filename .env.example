# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://taskuser:taskpass@postgres:5432/tasktracker?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_TTL_SECONDS=300

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=super_secret_access_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
